# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_ANALYTICS_ID: Google Analytics tracking ID (e.g., G-XXXXXXXXXX).
# Leave empty to disable analytics.
NEXT_PUBLIC_ANALYTICS_ID=""

# ── Supabase ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL: Your project's Supabase URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# NEXT_PUBLIC_SUPABASE_ANON_KEY: Safe to expose in the browser (respects RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# SUPABASE_SERVICE_ROLE_KEY: SECRET – never expose to the browser!
# Used server-side only for admin operations (creating users, bypassing RLS).
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# NEXT_PUBLIC_HCAPTCHA_SITE_KEY: Required for Supabase Auth Captcha bot detection (client-side).
# Use '10000000-ffff-ffff-ffff-000000000001' as the standard test key for local development.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="10000000-ffff-ffff-ffff-000000000001"

